#!/bin/bash
# Pre-commit hook for dark-bloom-manager
# Runs the same checks as CI to catch issues before push

set -e

echo "Running pre-commit checks..."

# Check formatting
echo "Checking formatting..."
if ! cargo fmt --all -- --check; then
    echo ""
    echo "Formatting check failed. Run 'cargo fmt --all' to fix."
    exit 1
fi

# Run clippy
echo "Running clippy..."
if ! cargo clippy --all-targets --all-features -- -D warnings; then
    echo ""
    echo "Clippy check failed. Fix the warnings above."
    exit 1
fi

# Run tests
echo "Running tests..."
if ! cargo test; then
    echo ""
    echo "Tests failed. Fix the failing tests above."
    exit 1
fi

echo "All pre-commit checks passed!"
